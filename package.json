{
  "name": "nkb-formulation-management-system",
  "version": "1.0.0",
  "description": "Production-ready Formulation Management System for Cosmetics, Perfumes, and Food Supplements",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "server": "node server/index.js",
    "migrate:latest": "knex migrate:latest --knexfile server/knexfile.js",
    "migrate:rollback": "knex migrate:rollback --knexfile server/knexfile.js",
    "seed:run": "knex seed:run --knexfile server/knexfile.js",
    "seed:admin": "node server/scripts/createSuperAdmin.js",
    "test": "vitest run"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "lucide-react": "^0.395.0",
    "mysql2": "^3.10.1",
    "puppeteer": "^22.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.0",
    "sqlite3": "^6.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.50.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "cross-env": "^7.0.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1",
    "vitest": "^1.6.0"
  }
}
