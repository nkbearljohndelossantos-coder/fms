PORT=5000
NODE_ENV=development

# Database configuration (mysql2 or sqlite3)
DB_CLIENT=sqlite3
DB_FILENAME=./database/nkb_formulation.sqlite

# MySQL Configuration (for Production)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=nkb_user
DB_PASSWORD=nkb_secure_password
DB_NAME=nkb_formulation_db

# Security & JWT Tokens
JWT_ACCESS_SECRET=nkb_access_super_secret_key_2026_change_in_production
JWT_REFRESH_SECRET=nkb_refresh_super_secret_key_2026_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Default System Admin setup
DEFAULT_ADMIN_EMAIL=admin@nkb.com
DEFAULT_ADMIN_PASSWORD=Admin@123456
